{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "SpaceTraffic": {
    "UserAgent": "SpaceTrafficETL/1.0 (+https://example.local/data-platform)",
    "Exasol": {
      "Host": "exasol",
      "Port": 8563,
      "Database": "",
      "Schema": "SPACE_TRAFFIC",
      "Username": "etl_user",
      "Password": "",
      "Fingerprint": "",
      "OdbcDriver": "EXASOL",
      "ConnectionTimeout": "00:00:30"
    },
    "DataDirectories": {
      "StorageRoot": "data",
      "Raw": "raw",
      "Staging": "staging",
      "Processed": "processed",
      "Rejected": "rejected"
    },
    "Etl": {
      "RunOnStartup": true,
      "Interval": "24:00:00",
      "DailyRunTimeUtc": "02:00:00",
      "DownloadTimeout": "00:02:00",
      "MaxDownloadRetries": 3,
      "DownloadRetryDelay": "00:00:05"
    },
    "CelesTrak": {
      "Enabled": true,
      "RawFileExtension": ".json",
      "Sources": [
        {
          "Name": "celestrak-active",
          "Kind": "CelesTrakJson",
          "Url": "https://celestrak.org/NORAD/elements/gp.php?GROUP=active&FORMAT=json",
          "RawFileExtension": ".json"
        },
        {
          "Name": "celestrak-debris",
          "Kind": "CelesTrakJson",
          "Url": "https://celestrak.org/NORAD/elements/gp.php?GROUP=debris&FORMAT=json",
          "RawFileExtension": ".json"
        },
        {
          "Name": "celestrak-starlink",
          "Kind": "CelesTrakJson",
          "Url": "https://celestrak.org/NORAD/elements/gp.php?GROUP=starlink&FORMAT=json",
          "RawFileExtension": ".json"
        },
        {
          "Name": "celestrak-geo",
          "Kind": "CelesTrakJson",
          "Url": "https://celestrak.org/NORAD/elements/gp.php?GROUP=geo&FORMAT=json",
          "RawFileExtension": ".json"
        },
        {
          "Name": "celestrak-stations",
          "Kind": "CelesTrakJson",
          "Url": "https://celestrak.org/NORAD/elements/gp.php?GROUP=stations&FORMAT=json",
          "RawFileExtension": ".json"
        },
        {
          "Name": "celestrak-last-30-days",
          "Kind": "CelesTrakJson",
          "Url": "https://celestrak.org/NORAD/elements/gp.php?GROUP=last-30-days&FORMAT=json",
          "RawFileExtension": ".json"
        }
      ]
    },
    "Ucs": {
      "Enabled": true,
      "SatelliteDatabasePageUrl": "https://www.ucsusa.org/resources/satellite-database",
      "SatelliteDatabaseDownloadUrl": "https://www.ucsusa.org/resources/satellite-database",
      "RawFileExtension": ".html"
    },
    "LaunchData": {
      "Enabled": true,
      "LaunchesUrl": "https://ll.thespacedevs.com/2.2.0/launch/",
      "RawFileExtension": ".json"
    },
    "Csv": {
      "OutputDirectory": "staging",
      "Delimiter": ",",
      "IncludeHeader": true
    }
  }
}
