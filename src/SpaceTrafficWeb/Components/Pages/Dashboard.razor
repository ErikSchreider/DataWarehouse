@page "/"
@inject IDashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<h1 class="h3 mb-4">Dashboard</h1>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (summary is null)
{
    <p>Loading...</p>
}
else
{
    <div class="row g-3">
        <div class="col-md-3">
            <div class="metric">
                <div class="metric-label">Objects total</div>
                <div class="metric-value">@summary.TotalObjects</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric">
                <div class="metric-label">Active satellites</div>
                <div class="metric-value">@summary.ActiveSatellites</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric">
                <div class="metric-label">Debris objects</div>
                <div class="metric-value">@summary.DebrisObjects</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric">
                <div class="metric-label">Last import</div>
                <div class="metric-value small-value">@FormatDate(summary.LastImportTimestamp)</div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardSummary? summary;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            summary = await DashboardService.GetDashboardSummaryAsync(CancellationToken.None);
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private static string FormatDate(DateTime? value)
    {
        return value?.ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a";
    }
}
