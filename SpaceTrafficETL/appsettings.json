{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "SpaceTraffic": {
    "UserAgent": "SpaceTrafficETL/1.0 (+https://example.local/data-platform)",
    "Exasol": {
      "Host": "exasol.example.local",
      "Port": 8563,
      "Database": "DW",
      "Schema": "STAGING",
      "Username": "etl_user",
      "Password": "",
      "ImportTable": "SATELLITE_TLE_STAGE",
      "ConnectionTimeout": "00:00:30"
    },
    "DataDirectories": {
      "StorageRoot": "data",
      "Raw": "raw",
      "Staging": "staging",
      "Processed": "processed",
      "Rejected": "rejected"
    },
    "Etl": {
      "RunOnStartup": true,
      "Interval": "24:00:00",
      "DailyRunTimeUtc": "02:00:00",
      "DownloadTimeout": "00:02:00",
      "MaxDownloadRetries": 3,
      "DownloadRetryDelay": "00:00:05"
    },
    "CelesTrak": {
      "Enabled": true,
      "ActiveSatellitesTleUrl": "https://celestrak.org/NORAD/elements/gp.php?GROUP=active&FORMAT=tle",
      "StationsTleUrl": "https://celestrak.org/NORAD/elements/gp.php?GROUP=stations&FORMAT=tle",
      "GpQueryBaseUrl": "https://celestrak.org/NORAD/elements/gp.php",
      "RawFileExtension": ".tle"
    },
    "Ucs": {
      "Enabled": true,
      "SatelliteDatabasePageUrl": "https://www.ucsusa.org/resources/satellite-database",
      "SatelliteDatabaseDownloadUrl": "https://www.ucsusa.org/resources/satellite-database",
      "RawFileExtension": ".html"
    },
    "LaunchData": {
      "Enabled": false,
      "UpcomingLaunchesUrl": "https://ll.thespacedevs.com/2.3.0/launches/upcoming/",
      "RawFileExtension": ".json"
    },
    "Csv": {
      "OutputDirectory": "staging",
      "Delimiter": ",",
      "IncludeHeader": true
    }
  }
}
